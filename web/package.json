{
  "name": "edgion-dashboard",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "test": "vitest run",
    "test:watch": "vitest",
    "e2e:install": "playwright install chromium",
    "e2e": "playwright test",
    "e2e:standalone": "E2E_MODE=standalone playwright test",
    "e2e:kubernetes": "E2E_MODE=kubernetes playwright test",
    "e2e:inventory": "tsx e2e/scripts/check-inventory.ts",
    "e2e:cases": "tsx e2e/scripts/generate-cases.ts",
    "e2e:typecheck": "tsc -p e2e/tsconfig.json --noEmit",
    "lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "preview": "vite preview"
  },
  "dependencies": {
    "@antv/g6": "^5.1.0",
    "@monaco-editor/react": "^4.6.0",
    "@tanstack/react-query": "^5.14.0",
    "antd": "^5.12.0",
    "axios": "^1.6.0",
    "dayjs": "^1.11.0",
    "js-yaml": "^4.1.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^6.20.0",
    "zod": "^4.2.1",
    "zustand": "^4.4.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^14.3.1",
    "@testing-library/user-event": "^14.6.1",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^20.19.43",
    "@types/react": "^18.2.43",
    "@types/react-dom": "^18.2.17",
    "@typescript-eslint/eslint-plugin": "^6.14.0",
    "@typescript-eslint/parser": "^6.14.0",
    "@vitejs/plugin-react": "^4.2.1",
    "eslint": "^8.55.0",
    "eslint-plugin-react-hooks": "^4.6.0",
    "eslint-plugin-react-refresh": "^0.4.5",
    "jsdom": "^24.1.3",
    "tsx": "^4.23.1",
    "typescript": "^5.2.2",
    "vite": "^5.0.8",
    "vitest": "^1.6.1"
  },
  "overrides": {
    "dompurify": "3.4.12"
  }
}
